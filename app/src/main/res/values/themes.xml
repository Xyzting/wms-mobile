<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Base.WMSMobile" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="textAppearanceHeadlineMedium">@style/TextAppearance.WMS.HeadlineMedium</item>
        <item name="textAppearanceHeadlineSmall">@style/TextAppearance.WMS.HeadlineSmall</item>
        <item name="textAppearanceTitleLarge">@style/TextAppearance.WMS.TitleLarge</item>
        <item name="textAppearanceTitleMedium">@style/TextAppearance.WMS.TitleMedium</item>
        <item name="textAppearanceLabelLarge">@style/TextAppearance.WMS.LabelLarge</item>

        <item name="android:statusBarColor">@color/latar_toolbar</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">false</item>
    </style>

    <style name="Theme.WMSMobile" parent="Base.WMSMobile">
        <item name="colorPrimary">@color/biru_utama</item>
        <item name="colorOnPrimary">@color/putih</item>
        <item name="colorPrimaryContainer">@color/biru_kontainer</item>
        <item name="colorOnPrimaryContainer">@color/biru_gelap</item>

        <item name="colorSecondary">@color/jingga_aksen</item>
        <item name="colorOnSecondary">@color/putih</item>
        <item name="colorSecondaryContainer">@color/jingga_kontainer</item>
        <item name="colorOnSecondaryContainer">@color/biru_gelap</item>

        <item name="colorTertiary">@color/hijau_aman</item>
        <item name="colorOnTertiary">@color/putih</item>
        <item name="colorTertiaryContainer">@color/hijau_kontainer</item>
        <item name="colorOnTertiaryContainer">@color/hijau_gelap</item>

        <item name="colorError">@color/merah_galat</item>
        <item name="colorOnError">@color/putih</item>
        <item name="colorErrorContainer">@color/merah_kontainer</item>
        <item name="colorOnErrorContainer">@color/merah_galat</item>

        <item name="android:colorBackground">@color/abu_latar</item>
        <item name="colorOnBackground">@color/biru_gelap</item>
        <item name="colorSurface">@color/abu_permukaan</item>
        <item name="colorOnSurface">@color/biru_gelap</item>
        <item name="colorSurfaceVariant">@color/abu_permukaan_varian</item>
        <item name="colorOnSurfaceVariant">@color/abu_teks</item>
        <item name="colorOutline">@color/abu_garis</item>
        <item name="colorOutlineVariant">@color/abu_garis_redup</item>
    </style>

</resources>
